meta {
  name: retrieve contact subscription via subscriptions summary
  type: http
  seq: 2
}

get {
  url: https://{{host}}/{{environment}}/{{client_token}}/subscription_summary?contact={{contactId}}
  body: none
  auth: none
}

params:query {
  contact: {{contactId}}
}

vars:post-response {
  subscriptionId: res.body["subscriptions"]?.[0]?.["@id"]
  subscriptionEngagedThrough: res.body["subscriptions"]?.[0]?.["engagedThrough"]
}
