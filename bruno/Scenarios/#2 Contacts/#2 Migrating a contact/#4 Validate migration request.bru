meta {
  name: #4 Validate migration request
  type: http
  seq: 4
}

post {
  url: https://{{host}}/{{environment}}/{{contactMigrationRequestId}}/transitions
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{jwtToken}}
  x-user-network-node-id: {{clubTwoNetworkNodeId}}
  x-user-club-id: {{clubTwoId}}
}

body:json {
  {
      "transition": "validate",
      "code": "522519"
  }
}

body:multipart-form {
  grant_type: client_credentials
  client_id: {{clientId}}
  client_secret: {{clientSecret}}
}

vars:post-response {
  resultTargetId: res.body?.["resultTargetId"]
}
