meta {
  name: #1 retrieve a random contact with an active subscription
  type: http
  seq: 1
}

get {
  url: https://{{host}}/{{environment}}/{{client_token}}/subscriptions?engagedThrough[after]={{startDate}}
  body: none
  auth: none
}

params:query {
  engagedThrough[after]: {{startDate}}
}

vars:post-response {
  contactId: res.body["hydra:member"]?.[0]?.["contact"]["@id"]
}

script:post-response {
  bru.setVar('startDate', (new Date()).toISOString().split('T')[0]);
}
