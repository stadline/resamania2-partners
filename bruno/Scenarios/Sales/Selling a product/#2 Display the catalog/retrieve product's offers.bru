meta {
  name: retrieve product's offers
  type: http
  seq: 2
}

get {
  url: https://{{host}}/{{environment}}/{{client_token}}/offers?product={{productId}}
  body: none
  auth: none
}

params:query {
  product: {{productId}}
}

vars:post-response {
  offerId: res.body["hydra:member"]?.[0]?.["@id"]
}
